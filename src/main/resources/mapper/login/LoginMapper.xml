<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.feedapi.login.mapper.LoginMapper">

    <select id="getMember" parameterType="org.feedapi.login.dto.LoginDTO" resultType="org.feedapi.login.dto.LoginDTO">
        SELECT USER_ID AS userId
             , USER_PASSWORD AS userPassword
        FROM MEMBER
        WHERE USER_ID = #{userId}
    </select>

</mapper>